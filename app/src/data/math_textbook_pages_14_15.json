"section": {
"no": 3,
"title": "学びを深めよう",
"category": "正の数・負の数"
},
"prompt": {
"text": "ある日の最低気温は−2℃で，その前日の最低気温がある日の最低気温よりも1℃高かったそうです。その前日の最低気温を求める式として正しいものはどれですか。次のア〜エから選びなさい。"
},
"visuals": [],
"response": {
"type": "choice",
"multiple": false,
"choices": [
{
"key": "ア",
"text": "(-2)+(+1)"
},
{
"key": "イ",
"text": "(+1)+(-2)"
},
{
"key": "ウ",
"text": "(-2)-(+1)"
},
{
"key": "エ",
"text": "(+1)-(-2)"
}
]
},
"answer": {
"value": [
"ア"
]
},
"explanation": "−2℃より1℃高い温度は，−2に+1をした値で表せる。",
"notes": "",
"uncertain": false
}
]
}
]
